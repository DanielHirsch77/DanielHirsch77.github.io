// @version=5
// VERSION-CHECK: v9 (2026-06-04)
indicator("Gold Macro Events", overlay=true, shorttitle="GoldNarr", max_lines_count=300, max_labels_count=300)

show_cpi = input.bool(true, "CPI 8:30 ET", group="Events")
show_pce = input.bool(true, "PCE 8:30 ET", group="Events")
show_fomc = input.bool(true, "FOMC 14:00 ET", group="Events")
show_ppi = input.bool(false, "PPI 8:30 ET", group="Events")
show_nfp = input.bool(false, "NFP 8:30 ET", group="Events")
ltr = input.int(60, "Linie Transparenz", minval=0, maxval=95, group="Stil")
bgt = input.int(88, "Hintergrund Transparenz", minval=70, maxval=97, group="Stil")
show_bg = input.bool(true, "Hintergrundfarbe", group="Stil")
c_cpi = input.color(#ff9800, "CPI", group="Farben")
c_pce = input.color(#2196f3, "PCE", group="Farben")
c_fomc = input.color(#ef5350, "FOMC", group="Farben")
c_ppi = input.color(#9c27b0, "PPI", group="Farben")
c_nfp = input.color(#26a69a, "NFP", group="Farben")

f_draw(col, txt) =>
    line.new(bar_index, 0.01, bar_index, 99999.0, xloc=xloc.bar_index, color=color.new(col, ltr), width=1)
    label.new(bar_index, 0, txt, xloc=xloc.bar_index, yloc=yloc.abovebar, color=color.new(col, 72), textcolor=color.white, style=label.style_label_down, size=size.small)

yr = year(time)
mo = month(time)
dy = dayofmonth(time)

is_cpi = (yr==2024 and mo==1 and dy==11) or (yr==2024 and mo==2 and dy==13) or (yr==2024 and mo==3 and dy==12) or (yr==2024 and mo==4 and dy==10) or (yr==2024 and mo==5 and dy==15) or (yr==2024 and mo==6 and dy==12) or (yr==2024 and mo==7 and dy==11) or (yr==2024 and mo==8 and dy==14) or (yr==2024 and mo==9 and dy==11) or (yr==2024 and mo==10 and dy==10) or (yr==2024 and mo==11 and dy==13) or (yr==2024 and mo==12 and dy==11)
is_cpi := is_cpi or (yr==2025 and mo==1 and dy==15) or (yr==2025 and mo==2 and dy==12) or (yr==2025 and mo==3 and dy==12) or (yr==2025 and mo==4 and dy==10) or (yr==2025 and mo==5 and dy==13) or (yr==2025 and mo==6 and dy==11) or (yr==2025 and mo==7 and dy==15) or (yr==2025 and mo==8 and dy==12) or (yr==2025 and mo==9 and dy==10) or (yr==2025 and mo==10 and dy==15) or (yr==2025 and mo==11 and dy==12) or (yr==2025 and mo==12 and dy==10)
is_cpi := is_cpi or (yr==2026 and mo==1 and dy==14) or (yr==2026 and mo==2 and dy==11) or (yr==2026 and mo==3 and dy==11) or (yr==2026 and mo==4 and dy==10) or (yr==2026 and mo==5 and dy==13) or (yr==2026 and mo==6 and dy==10) or (yr==2026 and mo==7 and dy==15) or (yr==2026 and mo==8 and dy==12) or (yr==2026 and mo==9 and dy==9) or (yr==2026 and mo==10 and dy==14) or (yr==2026 and mo==11 and dy==12) or (yr==2026 and mo==12 and dy==9)

is_pce = (yr==2024 and mo==2 and dy==29) or (yr==2024 and mo==3 and dy==29) or (yr==2024 and mo==4 and dy==26) or (yr==2024 and mo==5 and dy==31) or (yr==2024 and mo==6 and dy==28) or (yr==2024 and mo==7 and dy==26) or (yr==2024 and mo==8 and dy==30) or (yr==2024 and mo==9 and dy==27) or (yr==2024 and mo==10 and dy==31) or (yr==2024 and mo==11 and dy==27) or (yr==2024 and mo==12 and dy==20)
is_pce := is_pce or (yr==2025 and mo==1 and dy==31) or (yr==2025 and mo==2 and dy==28) or (yr==2025 and mo==3 and dy==28) or (yr==2025 and mo==4 and dy==30) or (yr==2025 and mo==5 and dy==30) or (yr==2025 and mo==6 and dy==27) or (yr==2025 and mo==7 and dy==31) or (yr==2025 and mo==8 and dy==29) or (yr==2025 and mo==9 and dy==26) or (yr==2025 and mo==10 and dy==31) or (yr==2025 and mo==11 and dy==26) or (yr==2025 and mo==12 and dy==19)
is_pce := is_pce or (yr==2026 and mo==1 and dy==30) or (yr==2026 and mo==2 and dy==27) or (yr==2026 and mo==3 and dy==27) or (yr==2026 and mo==4 and dy==30) or (yr==2026 and mo==5 and dy==29) or (yr==2026 and mo==6 and dy==26)

is_fomc = (yr==2024 and mo==1 and dy==31) or (yr==2024 and mo==3 and dy==20) or (yr==2024 and mo==5 and dy==1) or (yr==2024 and mo==6 and dy==12) or (yr==2024 and mo==7 and dy==31) or (yr==2024 and mo==9 and dy==18) or (yr==2024 and mo==11 and dy==7) or (yr==2024 and mo==12 and dy==18)
is_fomc := is_fomc or (yr==2025 and mo==1 and dy==29) or (yr==2025 and mo==3 and dy==19) or (yr==2025 and mo==5 and dy==7) or (yr==2025 and mo==6 and dy==18) or (yr==2025 and mo==7 and dy==30) or (yr==2025 and mo==9 and dy==17) or (yr==2025 and mo==10 and dy==29) or (yr==2025 and mo==12 and dy==10)
is_fomc := is_fomc or (yr==2026 and mo==1 and dy==28) or (yr==2026 and mo==3 and dy==18) or (yr==2026 and mo==5 and dy==6) or (yr==2026 and mo==6 and dy==17) or (yr==2026 and mo==7 and dy==29) or (yr==2026 and mo==9 and dy==16) or (yr==2026 and mo==10 and dy==28) or (yr==2026 and mo==12 and dy==9)

is_ppi = (yr==2024 and mo==1 and dy==12) or (yr==2024 and mo==2 and dy==16) or (yr==2024 and mo==3 and dy==14) or (yr==2024 and mo==4 and dy==11) or (yr==2024 and mo==5 and dy==14) or (yr==2024 and mo==6 and dy==13) or (yr==2024 and mo==7 and dy==12) or (yr==2024 and mo==8 and dy==13) or (yr==2024 and mo==9 and dy==12) or (yr==2024 and mo==10 and dy==11) or (yr==2024 and mo==11 and dy==14) or (yr==2024 and mo==12 and dy==12)
is_ppi := is_ppi or (yr==2025 and mo==1 and dy==14) or (yr==2025 and mo==2 and dy==13) or (yr==2025 and mo==3 and dy==13) or (yr==2025 and mo==4 and dy==11) or (yr==2025 and mo==5 and dy==15) or (yr==2025 and mo==6 and dy==12) or (yr==2025 and mo==7 and dy==15) or (yr==2025 and mo==8 and dy==14) or (yr==2025 and mo==9 and dy==11) or (yr==2025 and mo==10 and dy==14) or (yr==2025 and mo==11 and dy==13) or (yr==2025 and mo==12 and dy==11)
is_ppi := is_ppi or (yr==2026 and mo==1 and dy==15) or (yr==2026 and mo==2 and dy==12) or (yr==2026 and mo==3 and dy==12) or (yr==2026 and mo==4 and dy==9) or (yr==2026 and mo==5 and dy==14) or (yr==2026 and mo==6 and dy==11)

is_nfp = (yr==2024 and mo==1 and dy==5) or (yr==2024 and mo==2 and dy==2) or (yr==2024 and mo==3 and dy==8) or (yr==2024 and mo==4 and dy==5) or (yr==2024 and mo==5 and dy==3) or (yr==2024 and mo==6 and dy==7) or (yr==2024 and mo==7 and dy==5) or (yr==2024 and mo==8 and dy==2) or (yr==2024 and mo==9 and dy==6) or (yr==2024 and mo==10 and dy==4) or (yr==2024 and mo==11 and dy==1) or (yr==2024 and mo==12 and dy==6)
is_nfp := is_nfp or (yr==2025 and mo==1 and dy==10) or (yr==2025 and mo==2 and dy==7) or (yr==2025 and mo==3 and dy==7) or (yr==2025 and mo==4 and dy==4) or (yr==2025 and mo==5 and dy==2) or (yr==2025 and mo==6 and dy==6) or (yr==2025 and mo==7 and dy==3) or (yr==2025 and mo==8 and dy==1) or (yr==2025 and mo==9 and dy==5) or (yr==2025 and mo==10 and dy==3) or (yr==2025 and mo==11 and dy==7) or (yr==2025 and mo==12 and dy==5)
is_nfp := is_nfp or (yr==2026 and mo==1 and dy==9) or (yr==2026 and mo==2 and dy==6) or (yr==2026 and mo==3 and dy==6) or (yr==2026 and mo==4 and dy==3) or (yr==2026 and mo==5 and dy==8) or (yr==2026 and mo==6 and dy==5)

bgcolor(show_bg and show_cpi and is_cpi ? color.new(c_cpi, bgt) : na)
bgcolor(show_bg and show_pce and is_pce ? color.new(c_pce, bgt) : na)
bgcolor(show_bg and show_fomc and is_fomc ? color.new(c_fomc, bgt) : na)
bgcolor(show_bg and show_ppi and is_ppi ? color.new(c_ppi, bgt) : na)
bgcolor(show_bg and show_nfp and is_nfp ? color.new(c_nfp, bgt) : na)

if barstate.isconfirmed
    if show_cpi and is_cpi
        f_draw(c_cpi, "CPI\n8:30 ET")
    if show_pce and is_pce
        f_draw(c_pce, "PCE\n8:30 ET")
    if show_fomc and is_fomc
        f_draw(c_fomc, "FOMC\n14:00 ET")
    if show_ppi and is_ppi
        f_draw(c_ppi, "PPI\n8:30 ET")
    if show_nfp and is_nfp
        f_draw(c_nfp, "NFP\n8:30 ET")

alertcondition(show_cpi and is_cpi, "CPI", "Gold: CPI 8:30 ET")
alertcondition(show_pce and is_pce, "PCE", "Gold: PCE 8:30 ET")
alertcondition(show_fomc and is_fomc, "FOMC", "Gold: FOMC 14:00 ET")
alertcondition(show_ppi and is_ppi, "PPI", "Gold: PPI 8:30 ET")
alertcondition(show_nfp and is_nfp, "NFP", "Gold: NFP 8:30 ET")
