//@version=6
// =============================================================================
//  GOLD MACRO NARRATIVE EVENTS  ·  CPI / PCE / NFP / FOMC / PPI
// -----------------------------------------------------------------------------
//  Zeichnet wichtige US-Makro-Termine als senkrechte Linie + Infotext-Block
//  direkt in den Gold-Chart (XAU/USD). Zeiten werden in deutscher Zeit
//  (MEZ/MESZ) angezeigt.
//
//  WICHTIG – manuelle Pflege:
//  Pine Script kann KEINE Live-Daten / keinen Wirtschaftskalender abrufen.
//  Du trägst die Termine unten in der Tabelle "EVENTS" selbst ein.
//  Format pro Zeile:  addEvent(JAHR, MONAT, TAG, STUNDE_ET, MINUTE_ET, "TYP", "INFOTEXT")
//  -> Stunde/Minute in US-Ostküstenzeit (ET) eintragen, da die US-Daten so
//     terminiert sind (CPI/NFP/PPI meist 08:30 ET, FOMC meist 14:00 ET).
//     Das Script rechnet selbst nach deutscher Zeit um und zeigt sie an.
// =============================================================================

indicator("Gold Macro Narrative Events", overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500)

// ----------------------------- EINSTELLUNGEN --------------------------------
grpFilter = "Event-Typen anzeigen"
showCPI   = input.bool(true,  "CPI  (Verbraucherpreise / Inflation)", group = grpFilter)
showPCE   = input.bool(true,  "PCE  (Fed-bevorzugtes Inflationsmaß)", group = grpFilter)
showNFP   = input.bool(true,  "NFP  (Arbeitsmarktbericht)",           group = grpFilter)
showFOMC  = input.bool(true,  "FOMC (Zinsentscheidung)",              group = grpFilter)
showPPI   = input.bool(true,  "PPI  (Erzeugerpreise)",                group = grpFilter)

grpStyle  = "Darstellung"
lineWidth = input.int(2, "Linienbreite", minval = 1, maxval = 4, group = grpStyle)
lineStyleSel = input.string("Gestrichelt", "Linienstil", options = ["Durchgezogen", "Gestrichelt", "Gepunktet"], group = grpStyle)
labelSize = input.string("Normal", "Textgröße", options = ["Klein", "Normal", "Groß", "Riesig"], group = grpStyle)
showCountdownTbl = input.bool(true, "Tabelle: nächstes Event oben rechts", group = grpStyle)
maxFutureDays = input.int(120, "Nur Events der letzten/nächsten X Tage", minval = 7, maxval = 720, group = grpStyle)

grpColor = "Farben"
colCPI   = input.color(color.new(#e74c3c, 0), "CPI",  group = grpColor, inline = "c1")
colPCE   = input.color(color.new(#e67e22, 0), "PCE",  group = grpColor, inline = "c1")
colNFP   = input.color(color.new(#3498db, 0), "NFP",  group = grpColor, inline = "c2")
colFOMC  = input.color(color.new(#9b59b6, 0), "FOMC", group = grpColor, inline = "c2")
colPPI   = input.color(color.new(#16a085, 0), "PPI",  group = grpColor, inline = "c3")

// --------------------------- HILFSFUNKTIONEN --------------------------------
// Liniendarstellung
f_lineStyle() =>
    lineStyleSel == "Durchgezogen" ? line.style_solid : lineStyleSel == "Gepunktet" ? line.style_dotted : line.style_dashed

f_labelSize() =>
    labelSize == "Klein" ? size.small : labelSize == "Normal" ? size.normal : labelSize == "Groß" ? size.large : size.huge

// Event-Typ -> Farbe
f_color(string t) =>
    t == "CPI"  ? colCPI  :
     t == "PCE"  ? colPCE  :
     t == "NFP"  ? colNFP  :
     t == "FOMC" ? colFOMC :
     t == "PPI"  ? colPPI  : color.gray

// Event-Typ -> ist eingeschaltet?
f_enabled(string t) =>
    t == "CPI"  ? showCPI  :
     t == "PCE"  ? showPCE  :
     t == "NFP"  ? showNFP  :
     t == "FOMC" ? showFOMC :
     t == "PPI"  ? showPPI  : false

// ET -> deutsche Zeit (MEZ/MESZ) als lesbarer String "HH:MM"
// Wir lassen Pine die Zeitzonen-Umrechnung machen, indem wir den UTC-Zeitstempel
// des Events bilden und ihn in "Europe/Berlin" formatieren.
// Da US-DST und EU-DST nicht exakt gleich schalten, ist die ET->UTC-Offsetwahl
// approximativ über den Monat gelöst (ET = UTC-4 in Sommerzeit, UTC-5 Winter).
f_etToUtcMillis(int y, int mo, int d, int hET, int mnET) =>
    // grobe US-DST-Regel: DST aktiv ca. März..November
    bool usDst = mo > 3 and mo < 11
    int offset = usDst ? 4 : 5            // Stunden, die man zu ET addiert, um UTC zu bekommen
    timestamp("GMT+0", y, mo, d, hET + offset, mnET)

// formatiert einen UTC-Millis-Zeitstempel als deutsche Ortszeit
f_fmtBerlin(int ms) =>
    str.format_time(ms, "dd.MM.yyyy  HH:mm", "Europe/Berlin")

// ------------------------------ EVENT-SPEICHER ------------------------------
// Wir sammeln Events in Arrays. addEvent() füllt sie.
var int[]    evTime  = array.new_int()      // UTC-Millis des Events
var string[] evType  = array.new_string()   // "CPI" etc.
var string[] evInfo  = array.new_string()   // Freitext

addEvent(int y, int mo, int d, int hET, int mnET, string t, string info) =>
    int ms = f_etToUtcMillis(y, mo, d, hET, mnET)
    array.push(evTime, ms)
    array.push(evType, t)
    array.push(evInfo, info)

// =============================================================================
//  EVENTS  ·  HIER PFLEGEN
//  Stunde/Minute in ET. Typische Zeiten: CPI/PPI/NFP = 8:30 ET, FOMC = 14:00 ET,
//  PCE = 8:30 ET. Passe Werte/Texte nach Veröffentlichung an.
//  (Beispiel-Termine 2025/2026 – bitte gegen offiziellen Kalender prüfen!)
// =============================================================================
