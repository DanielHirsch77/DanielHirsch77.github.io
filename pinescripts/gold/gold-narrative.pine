// This source code is subject to the terms of the Mozilla Public License 2.0
// @version=5
indicator("Gold Macro Events", overlay=true, shorttitle="GoldNarr", max_lines_count=300, max_labels_count=300)

// ---- Inputs ----------------------------------------------------------------
show_cpi  = input.bool(true,  "CPI  8:30 ET",  group="Events")
show_pce  = input.bool(true,  "PCE  8:30 ET",  group="Events")
show_fomc = input.bool(true,  "FOMC 14:00 ET", group="Events")
show_ppi  = input.bool(false, "PPI  8:30 ET",  group="Events")
show_nfp  = input.bool(false, "NFP  8:30 ET",  group="Events")
ltr  = input.int(60, "Linie Transparenz", minval=0, maxval=95, group="Stil")
bgt  = input.int(88, "Hintergrund Transparenz", minval=70, maxval=97, group="Stil")
show_bg = input.bool(true, "Hintergrundfarbe", group="Stil")
c_cpi  = input.color(#ff9800, "CPI",  group="Farben")
c_pce  = input.color(#2196f3, "PCE",  group="Farben")
c_fomc = input.color(#ef5350, "FOMC", group="Farben")
c_ppi  = input.color(#9c27b0, "PPI",  group="Farben")
c_nfp  = input.color(#26a69a, "NFP",  group="Farben")

// ---- Draw functions --------------------------------------------------------
f_draw(col, txt) =>
    line.new(bar_index, 0.01, bar_index, 99999.0, xloc=xloc.bar_index, color=color.new(col, ltr), width=1)
    label.new(bar_index, 0, text=txt, xloc=xloc.bar_index, yloc=yloc.abovebar, color=color.new(col, 72), textcolor=color.white, style=label.style_label_down, size=size.small)

// ---- Date check (no arrays, no loops) --------------------------------------
d = dayofmonth(time)
m = month(time)
y = year(time)

// CPI dates
cpi_2024 = (y==2024 and m==1 and d==11) or (y==2024 and m==2 and d==13) or (y==2024 and m==3 and d==12) or (y==2024 and m==4 and d==10) or (y==2024 and m==5 and d==15) or (y==2024 and m==6 and d==12)
cpi_2024b = (y==2024 and m==7 and d==11) or (y==2024 and m==8 and d==14) or (y==2024 and m==9 and d==11) or (y==2024 and m==10 and d==10) or (y==2024 and m==11 and d==13) or (y==2024 and m==12 and d==11)
cpi_2025 = (y==2025 and m==1 and d==15) or (y==2025 and m==2 and d==12) or (y==2025 and m==3 and d==12) or (y==2025 and m==4 and d==10) or (y==2025 and m==5 and d==13) or (y==2025 and m==6 and d==11)
cpi_2025b = (y==2025 and m==7 and d==15) or (y==2025 and m==8 and d==12) or (y==2025 and m==9 and d==10) or (y==2025 and m==10 and d==15) or (y==2025 and m==11 and d==12) or (y==2025 and m==12 and d==10)
cpi_2026 = (y==2026 and m==1 and d==14) or (y==2026 and m==2 and d==11) or (y==2026 and m==3 and d==11) or (y==2026 and m==4 and d==10) or (y==2026 and m==5 and d==13) or (y==2026 and m==6 and d==10)
cpi_2026b = (y==2026 and m==7 and d==15) or (y==2026 and m==8 and d==12) or (y==2026 and m==9 and d==9) or (y==2026 and m==10 and d==14) or (y==2026 and m==11 and d==12) or (y==2026 and m==12 and d==9)
is_cpi = cpi_2024 or cpi_2024b or cpi_2025 or cpi_2025b or cpi_2026 or cpi_2026b

// PCE dates
pce_2024 = (y==2024 and m==2 and d==29) or (y==2024 and m==3 and d==29) or (y==2024 and m==4 and d==26) or (y==2024 and m==5 and d==31) or (y==2024 and m==6 and d==28) or (y==2024 and m==7 and d==26)
pce_2024b = (y==2024 and m==8 and d==30) or (y==2024 and m==9 and d==27) or (y==2024 and m==10 and d==31) or (y==2024 and m==11 and d==27) or (y==2024 and m==12 and d==20)
pce_2025 = (y==2025 and m==1 and d==31) or (y==2025 and m==2 and d==28) or (y==2025 and m==3 and d==28) or (y==2025 and m==4 and d==30) or (y==2025 and m==5 and d==30) or (y==2025 and m==6 and d==27)
pce_2025b = (y==2025 and m==7 and d==31) or (y==2025 and m==8 and d==29) or (y==2025 and m==9 and d==26) or (y==2025 and m==10 and d==31) or (y==2025 and m==11 and d==26) or (y==2025 and m==12 and d==19)
pce_2026 = (y==2026 and m==1 and d==30) or (y==2026 and m==2 and d==27) or (y==2026 and m==3 and d==27) or (y==2026 and m==4 and d==30) or (y==2026 and m==5 and d==29) or (y==2026 and m==6 and d==26)
is_pce = pce_2024 or pce_2024b or pce_2025 or pce_2025b or pce_2026

// FOMC dates
fomc_2024 = (y==2024 and m==1 and d==31) or (y==2024 and m==3 and d==20) or (y==2024 and m==5 and d==1) or (y==2024 and m==6 and d==12) or (y==2024 and m==7 and d==31) or (y==2024 and m==9 and d==18) or (y==2024 and m==11 and d==7) or (y==2024 and m==12 and d==18)
fomc_2025 = (y==2025 and m==1 and d==29) or (y==2025 and m==3 and d==19) or (y==2025 and m==5 and d==7) or (y==2025 and m==6 and d==18) or (y==2025 and m==7 and d==30) or (y==2025 and m==9 and d==17) or (y==2025 and m==10 and d==29) or (y==2025 and m==12 and d==10)
fomc_2026 = (y==2026 and m==1 and d==28) or (y==2026 and m==3 and d==18) or (y==2026 and m==5 and d==6) or (y==2026 and m==6 and d==17) or (y==2026 and m==7 and d==29) or (y==2026 and m==9 and d==16) or (y==2026 and m==10 and d==28) or (y==2026 and m==12 and d==9)
is_fomc = fomc_2024 or fomc_2025 or fomc_2026

// PPI dates
ppi_2024 = (y==2024 and m==1 and d==12) or (y==2024 and m==2 and d==16) or (y==2024 and m==3 and d==14) or (y==2024 and m==4 and d==11) or (y==2024 and m==5 and d==14) or (y==2024 and m==6 and d==13)
ppi_2024b = (y==2024 and m==7 and d==12) or (y==2024 and m==8 and d==13) or (y==2024 and m==9 and d==12) or (y==2024 and m==10 and d==11) or (y==2024 and m==11 and d==14) or (y==2024 and m==12 and d==12)
ppi_2025 = (y==2025 and m==1 and d==14) or (y==2025 and m==2 and d==13) or (y==2025 and m==3 and d==13) or (y==2025 and m==4 and d==11) or (y==2025 and m==5 and d==15) or (y==2025 and m==6 and d==12)
ppi_2025b = (y==2025 and m==7 and d==15) or (y==2025 and m==8 and d==14) or (y==2025 and m==9 and d==11) or (y==2025 and m==10 and d==14) or (y==2025 and m==11 and d==13) or (y==2025 and m==12 and d==11)
ppi_2026 = (y==2026 and m==1 and d==15) or (y==2026 and m==2 and d==12) or (y==2026 and m==3 and d==12) or (y==2026 and m==4 and d==9) or (y==2026 and m==5 and d==14) or (y==2026 and m==6 and d==11)
is_ppi = ppi_2024 or ppi_2024b or ppi_2025 or ppi_2025b or ppi_2026

// NFP dates
nfp_2024 = (y==2024 and m==1 and d==5) or (y==2024 and m==2 and d==2) or (y==2024 and m==3 and d==8) or (y==2024 and m==4 and d==5) or (y==2024 and m==5 and d==3) or (y==2024 and m==6 and d==7)
nfp_2024b = (y==2024 and m==7 and d==5) or (y==2024 and m==8 and d==2) or (y==2024 and m==9 and d==6) or (y==2024 and m==10 and d==4) or (y==2024 and m==11 and d==1) or (y==2024 and m==12 and d==6)
nfp_2025 = (y==2025 and m==1 and d==10) or (y==2025 and m==2 and d==7) or (y==2025 and m==3 and d==7) or (y==2025 and m==4 and d==4) or (y==2025 and m==5 and d==2) or (y==2025 and m==6 and d==6)
nfp_2025b = (y==2025 and m==7 and d==3) or (y==2025 and m==8 and d==1) or (y==2025 and m==9 and d==5) or (y==2025 and m==10 and d==3) or (y==2025 and m==11 and d==7) or (y==2025 and m==12 and d==5)
nfp_2026 = (y==2026 and m==1 and d==9) or (y==2026 and m==2 and d==6) or (y==2026 and m==3 and d==6) or (y==2026 and m==4 and d==3) or (y==2026 and m==5 and d==8) or (y==2026 and m==6 and d==5)
is_nfp = nfp_2024 or nfp_2024b or nfp_2025 or nfp_2025b or nfp_2026

// ---- Background color ------------------------------------------------------
bg_col = show_bg and show_cpi and is_cpi ? color.new(c_cpi, bgt) : show_bg and show_pce and is_pce ? color.new(c_pce, bgt) : show_bg and show_fomc and is_fomc ? color.new(c_fomc, bgt) : show_bg and show_ppi and is_ppi ? color.new(c_ppi, bgt) : show_bg and show_nfp and is_nfp ? color.new(c_nfp, bgt) : na
bgcolor(bg_col, title="Event Hintergrund")

// ---- Lines and labels (confirmed bars only) --------------------------------
if barstate.isconfirmed
    if show_cpi and is_cpi
        f_draw(c_cpi, "CPI\n8:30 ET")
    if show_pce and is_pce
        f_draw(c_pce, "PCE\n8:30 ET")
    if show_fomc and is_fomc
        f_draw(c_fomc, "FOMC\n14:00 ET")
    if show_ppi and is_ppi
        f_draw(c_ppi, "PPI\n8:30 ET")
    if show_nfp and is_nfp
        f_draw(c_nfp, "NFP\n8:30 ET")

// ---- Alerts ----------------------------------------------------------------
alertcondition(show_cpi and is_cpi, "CPI", "Gold: CPI 8:30 ET")
alertcondition(show_pce and is_pce, "PCE", "Gold: PCE 8:30 ET")
alertcondition(show_fomc and is_fomc, "FOMC", "Gold: FOMC 14:00 ET")
alertcondition(show_ppi and is_ppi, "PPI", "Gold: PPI 8:30 ET")
alertcondition(show_nfp and is_nfp, "NFP", "Gold: NFP 8:30 ET")
