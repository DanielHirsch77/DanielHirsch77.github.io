// ----------------------------------------------------------------------------
// HAUPTLOGIK
// Jahresfilter (2024-2026) fuer Performance auf langen Historien
// ----------------------------------------------------------------------------

cur_yr   = year(time, "America/New_York")
in_range = cur_yr >= 2024 and cur_yr <= 2026

// Hintergrundfarbe (laeuft jede Bar durch damit bgcolor() korrekt feuert)
bg_col = color(na)
if in_range and show_bg
    for i = 0 to array.size(cpi_ts) - 1
        if show_cpi and bar_has_event(array.get(cpi_ts, i))
            bg_col := color.new(col_cpi, bg_transp)
    for i = 0 to array.size(pce_ts) - 1
        if show_pce and bar_has_event(array.get(pce_ts, i))
            bg_col := color.new(col_pce, bg_transp)
    for i = 0 to array.size(fomc_ts) - 1
        if show_fomc and bar_has_event(array.get(fomc_ts, i))
            bg_col := color.new(col_fomc, bg_transp)
    for i = 0 to array.size(ppi_ts) - 1
        if show_ppi and bar_has_event(array.get(ppi_ts, i))
            bg_col := color.new(col_ppi, bg_transp)
    for i = 0 to array.size(nfp_ts) - 1
        if show_nfp and bar_has_event(array.get(nfp_ts, i))
            bg_col := color.new(col_nfp, bg_transp)

bgcolor(bg_col, title = "Event Hintergrund")

// Linie + Label (nur auf abgeschlossenen Bars, kein Flackern auf Live-Bar)
if in_range and barstate.isconfirmed
    for i = 0 to array.size(cpi_ts) - 1
        if show_cpi and bar_has_event(array.get(cpi_ts, i))
            draw_event(col_cpi, "CPI\n8:30 ET")
    for i = 0 to array.size(pce_ts) - 1
        if show_pce and bar_has_event(array.get(pce_ts, i))
            draw_event(col_pce, "PCE\n8:30 ET")
    for i = 0 to array.size(fomc_ts) - 1
        if show_fomc and bar_has_event(array.get(fomc_ts, i))
            draw_event(col_fomc, "FOMC\n14:00 ET")
    for i = 0 to array.size(ppi_ts) - 1
        if show_ppi and bar_has_event(array.get(ppi_ts, i))
            draw_event(col_ppi, "PPI\n8:30 ET")
    for i = 0 to array.size(nfp_ts) - 1
        if show_nfp and bar_has_event(array.get(nfp_ts, i))
            draw_event(col_nfp, "NFP\n8:30 ET")

// ----------------------------------------------------------------------------
// ALERTS
// ----------------------------------------------------------------------------
alertcondition(show_cpi  and in_range, "CPI Event",  "Gold: CPI Veroeffentlichung - 8:30 ET")
alertcondition(show_pce  and in_range, "PCE Event",  "Gold: PCE Veroeffentlichung - 8:30 ET")
alertcondition(show_fomc and in_range, "FOMC Event", "Gold: FOMC Zinsentscheidung - 14:00 ET")
alertcondition(show_ppi  and in_range, "PPI Event",  "Gold: PPI Veroeffentlichung - 8:30 ET")
alertcondition(show_nfp  and in_range, "NFP Event",  "Gold: NFP Arbeitsmarktdaten - 8:30 ET")
