// =============================================================================
//  ZEICHNEN
//  Wir prüfen auf JEDER Bar, ob ein Event in diese Bar fällt (zwischen
//  time und time_close). Trifft es zu, zeichnen wir Linie + Label.
// =============================================================================
// Damit nichts doppelt gezeichnet wird, merken wir gezeichnete Indizes.
var bool[] drawn = array.new_bool()
if barstate.isfirst
    for i = 0 to (array.size(evTime) > 0 ? array.size(evTime) - 1 : 0)
        array.push(drawn, false)

barStartMs = time
barEndMs   = time_close
nowMs      = timenow

if array.size(evTime) > 0
    for i = 0 to array.size(evTime) - 1
        int ems = array.get(evTime, i)
        string et = array.get(evType, i)
        // Filter: Typ aktiv?  +  innerhalb Zeitfenster?
        bool withinWindow = math.abs(nowMs - ems) <= maxFutureDays * 86400000
        if f_enabled(et) and withinWindow and not array.get(drawn, i)
            // Fällt das Event in die aktuelle Bar?
            if ems >= barStartMs and ems < barEndMs
                col = f_color(et)
                // --- senkrechte Linie über die volle Höhe ---
                ln = line.new(x1 = bar_index, y1 = high, x2 = bar_index, y2 = low, xloc = xloc.bar_index, extend = extend.both, color = col, width = lineWidth, style = f_lineStyle())
                // --- großer Infotext-Block als Label ---
                string deTime = f_fmtBerlin(ems)
                string txt = et + "  ·  " + deTime + " (MEZ/MESZ)\n" + array.get(evInfo, i)
                label.new(x = bar_index, y = high, text = txt, xloc = xloc.bar_index, yloc = yloc.price, color = col, textcolor = color.white, style = label.style_label_down, size = f_labelSize(), textalign = text.align_left)
                array.set(drawn, i, true)

// =============================================================================
//  TABELLE: NÄCHSTES EVENT (oben rechts)
// =============================================================================
var table tbl = table.new(position.top_right, 1, 2, border_width = 1)

f_findNext() =>
    int bestMs = na
    int bestIdx = na
    if array.size(evTime) > 0
        for i = 0 to array.size(evTime) - 1
            int ems = array.get(evTime, i)
            if f_enabled(array.get(evType, i)) and ems >= nowMs
                if na(bestMs) or ems < bestMs
                    bestMs := ems
                    bestIdx := i
    [bestMs, bestIdx]

if showCountdownTbl and barstate.islast
    [nextMs, nextIdx] = f_findNext()
    if not na(nextIdx)
        string nt   = array.get(evType, nextIdx)
        string ninf = array.get(evInfo, nextIdx)
        // Countdown
        int diffMs  = nextMs - nowMs
        int days    = math.floor(diffMs / 86400000)
        int hours   = math.floor((diffMs % 86400000) / 3600000)
        int mins    = math.floor((diffMs % 3600000) / 60000)
        string head = "⏱ NÄCHSTES: " + nt
        string body = f_fmtBerlin(nextMs) + " MEZ/MESZ\n" + "in " + str.tostring(days) + "d " + str.tostring(hours) + "h " + str.tostring(mins) + "m\n" + ninf
        table.cell(tbl, 0, 0, head, text_color = color.white, bgcolor = f_color(nt), text_size = size.normal, text_halign = text.align_left)
        table.cell(tbl, 0, 1, body, text_color = color.white, bgcolor = color.new(color.black, 20), text_size = size.small, text_halign = text.align_left)

// =============================================================================
//  ALERTS – optional: Alert kurz vor jedem aktiven Event
// =============================================================================
alertcondition(true, title = "Macro-Event Hinweis", message = "Gold Macro Event nähert sich – siehe Chart")
