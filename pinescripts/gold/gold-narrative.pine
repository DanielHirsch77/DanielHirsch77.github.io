// This source code is subject to the terms of the Mozilla Public License 2.0
// @version=6
// =============================================================================
//  Gold Narrative - US Makro Events (CPI, PCE, FOMC, PPI, NFP)
//  Senkrechter Strich + Label fuer jeden Event-Bar, keine Kerzen verdeckt.
//  Daten: 2024-2026  (2026 teilweise geschaetzt)
// =============================================================================

indicator("Gold Narrative - US Makro Events",
     overlay          = true,
     shorttitle       = "GoldNarr",
     max_lines_count  = 500,
     max_labels_count = 500)

// --- Inputs ------------------------------------------------------------------

grp_ev = "Events einblenden"
show_cpi  = input.bool(true,  "CPI  8:30 ET",  group = grp_ev)
show_pce  = input.bool(true,  "PCE  8:30 ET",  group = grp_ev)
show_fomc = input.bool(true,  "FOMC 14:00 ET", group = grp_ev)
show_ppi  = input.bool(false, "PPI  8:30 ET",  group = grp_ev)
show_nfp  = input.bool(false, "NFP  8:30 ET",  group = grp_ev)

grp_st = "Darstellung"
ltr = input.int(60, "Linien-Transparenz", minval=0, maxval=95, group=grp_st)
bg  = input.bool(true, "Hintergrundfarbe", group=grp_st)
bgt = input.int(88, "Hintergrund-Transparenz", minval=70, maxval=97, group=grp_st)
lsz = input.string("small", "Labelgroesse",
     options=["tiny", "small", "normal"], group=grp_st)

grp_c = "Farben"
c_cpi  = input.color(#ff9800, "CPI",  group=grp_c, inline="a")
c_pce  = input.color(#2196f3, "PCE",  group=grp_c, inline="b")
c_fomc = input.color(#ef5350, "FOMC", group=grp_c, inline="c")
c_ppi  = input.color(#9c27b0, "PPI",  group=grp_c, inline="d")
c_nfp  = input.color(#26a69a, "NFP",  group=grp_c, inline="e")

// --- Helper functions --------------------------------------------------------

f_sz() =>
    lsz == "tiny" ? size.tiny : lsz == "normal" ? size.normal : size.small

f_match(ev_ts) =>
    if timeframe.isintraday
        time <= ev_ts and time_close > ev_ts
    else
        dayofmonth(ev_ts) == dayofmonth(time) and
        month(ev_ts)      == month(time)       and
        year(ev_ts)       == year(time)

f_draw(col, txt) =>
    line.new(bar_index, 0.01, bar_index, 99999.0,
         xloc  = xloc.bar_index,
         color = color.new(col, ltr),
         width = 1)
    label.new(bar_index, 0,
         text      = txt,
         xloc      = xloc.bar_index,
         yloc      = yloc.abovebar,
         color     = color.new(col, 72),
         textcolor = color.white,
         style     = label.style_label_down,
         size      = f_sz())

// --- Timestamps --------------------------------------------------------------

var int[] cpi_ts  = array.new<int>()
var int[] pce_ts  = array.new<int>()
var int[] fomc_ts = array.new<int>()
var int[] ppi_ts  = array.new<int>()
var int[] nfp_ts  = array.new<int>()

