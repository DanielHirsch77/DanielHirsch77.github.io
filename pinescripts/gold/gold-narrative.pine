// This source code is subject to the terms of the Mozilla Public License 2.0
// @version=5
// =============================================================================
//  Gold Narrative - US Makro Events
//
//  Markiert US-Inflationsdaten und Fed-Entscheidungen im Gold-Chart:
//    - Senkrechter Strich an jedem Event-Bar
//    - Dezentes Label (Typ + Uhrzeit ET) oberhalb der Kerzen
//    - Optionale Hintergrundfarbe des Event-Bars
//
//  Events:   CPI - PCE - FOMC - PPI - NFP
//  Zeiten:   America/New_York (DST automatisch korrekt)
//  Daten:    2024 - 2026  (2026 teilweise geschaetzt, BLS.gov pruefen)
// =============================================================================

indicator("Gold Narrative - US Makro Events",
     overlay          = true,
     shorttitle       = "GoldNarr",
     max_lines_count  = 500,
     max_labels_count = 500)

// ----------------------------------------------------------------------------
// EINSTELLUNGEN
// ----------------------------------------------------------------------------

grp_ev = "Events einblenden"
show_cpi  = input.bool(true,  "CPI  - Verbraucherpreise (8:30 ET)",  group = grp_ev)
show_pce  = input.bool(true,  "PCE  - Fed Inflationsmass (8:30 ET)", group = grp_ev)
show_fomc = input.bool(true,  "FOMC - Zinsentscheidung (14:00 ET)",  group = grp_ev)
show_ppi  = input.bool(false, "PPI  - Erzeugerpreise (8:30 ET)",     group = grp_ev)
show_nfp  = input.bool(false, "NFP  - Arbeitsmarkt (8:30 ET)",       group = grp_ev)

grp_style = "Darstellung"
line_transp = input.int(60, "Linien-Transparenz (0=voll, 95=fast unsichtbar)",
     minval = 0, maxval = 95, step = 5, group = grp_style)
show_bg   = input.bool(true, "Hintergrundfarbe des Event-Bars", group = grp_style)
bg_transp = input.int(88, "Hintergrund-Transparenz",
     minval = 70, maxval = 97, step = 1, group = grp_style)
lbl_size_in = input.string("small", "Labelgroesse",
     options = ["tiny", "small", "normal"], group = grp_style)

grp_col = "Farben"
col_cpi  = input.color(#ff9800, "CPI",  group = grp_col, inline = "c1")
col_pce  = input.color(#2196f3, "PCE",  group = grp_col, inline = "c2")
col_fomc = input.color(#ef5350, "FOMC", group = grp_col, inline = "c3")
col_ppi  = input.color(#9c27b0, "PPI",  group = grp_col, inline = "c4")
col_nfp  = input.color(#26a69a, "NFP",  group = grp_col, inline = "c5")

// ----------------------------------------------------------------------------
// HILFSFUNKTIONEN
// ----------------------------------------------------------------------------

lbl_sz() =>
    switch lbl_size_in
        "tiny"   => size.tiny
        "normal" => size.normal
        =>          size.small

// True, wenn der aktuelle Bar den Event-Zeitstempel enthaelt.
// Intraday: exakter Zeitvergleich. Daily+: nur Datum.
bar_has_event(ev_ts) =>
    if timeframe.isintraday
        time <= ev_ts and time_close > ev_ts
    else
        year(ev_ts,       "America/New_York") == year(time,       "America/New_York") and
        month(ev_ts,      "America/New_York") == month(time,      "America/New_York") and
        dayofmonth(ev_ts, "America/New_York") == dayofmonth(time, "America/New_York")

// Senkrechter Strich (0 -> 99999, TradingView clippt auf sichtbaren Bereich)
// + Label oberhalb der Kerze (keine Kerze wird verdeckt)
draw_event(ev_col, lbl_txt) =>
    line.new(bar_index, 0.01, bar_index, 99999.0,
         xloc  = xloc.bar_index,
         color = color.new(ev_col, line_transp),
         width = 1,
         style = line.style_solid)
    label.new(bar_index, 0,
         text      = lbl_txt,
         xloc      = xloc.bar_index,
         yloc      = yloc.abovebar,
         color     = color.new(ev_col, 72),
         textcolor = color.white,
         style     = label.style_label_down,
         size      = lbl_sz())

// ----------------------------------------------------------------------------
// EVENT-TIMESTAMPS  (America/New_York)
//   CPI / PCE / PPI / NFP : 8:30 AM ET
//   FOMC Zinsentscheidung  : 14:00 ET
//
//   timestamp("America/New_York", Jahr, Monat, Tag, Stunde, Minute)
//   -> DST wird von TradingView automatisch berechnet
//
//   2026: geschaetzte Daten - bitte auf BLS.gov und federalreserve.gov pruefen
// ----------------------------------------------------------------------------

