// --- Hilfsfunktionen ---------------------------------------------------------

f_sz() =>
    lsz == "tiny" ? size.tiny : lsz == "normal" ? size.normal : size.small

// Prueft ob der aktuelle Bar den Event-Zeitstempel enthaelt.
// Intraday: exaktes Zeitfenster. Daily+: Tagesvergleich.
f_match(ev_ts) =>
    if timeframe.isintraday
        time <= ev_ts and time_close > ev_ts
    else
        dayofmonth(ev_ts) == dayofmonth(time) and
        month(ev_ts)      == month(time)       and
        year(ev_ts)       == year(time)

// Zeichnet Linie (volle Charthoehe) + Label ueber dem Bar.
f_draw(col, txt) =>
    line.new(bar_index, 0.01, bar_index, 99999.0,
         xloc=xloc.bar_index,
         color=color.new(col, ltr),
         width=1)
    label.new(bar_index, 0,
         text=txt,
         xloc=xloc.bar_index,
         yloc=yloc.abovebar,
         color=color.new(col, 72),
         textcolor=color.white,
         style=label.style_label_down,
         size=f_sz())

// --- Hauptlogik --------------------------------------------------------------

in_range = year >= 2024 and year <= 2026

// Hintergrundfarbe (laeuft jede Bar, damit bgcolor() korrekt feuert)
var color bg_c = na
bg_c := na
if in_range and bg
    for i = 0 to array.size(cpi_ts) - 1
        if show_cpi and f_match(array.get(cpi_ts, i))
            bg_c := color.new(c_cpi, bgt)
    for i = 0 to array.size(pce_ts) - 1
        if show_pce and f_match(array.get(pce_ts, i))
            bg_c := color.new(c_pce, bgt)
    for i = 0 to array.size(fomc_ts) - 1
        if show_fomc and f_match(array.get(fomc_ts, i))
            bg_c := color.new(c_fomc, bgt)
    for i = 0 to array.size(ppi_ts) - 1
        if show_ppi and f_match(array.get(ppi_ts, i))
            bg_c := color.new(c_ppi, bgt)
    for i = 0 to array.size(nfp_ts) - 1
        if show_nfp and f_match(array.get(nfp_ts, i))
            bg_c := color.new(c_nfp, bgt)

bgcolor(bg_c, title="Event Hintergrund")

// Linie + Label nur auf abgeschlossenen Bars (kein Flackern)
if in_range and barstate.isconfirmed
    for i = 0 to array.size(cpi_ts) - 1
        if show_cpi and f_match(array.get(cpi_ts, i))
            f_draw(c_cpi, "CPI\n8:30 ET")
    for i = 0 to array.size(pce_ts) - 1
        if show_pce and f_match(array.get(pce_ts, i))
            f_draw(c_pce, "PCE\n8:30 ET")
    for i = 0 to array.size(fomc_ts) - 1
        if show_fomc and f_match(array.get(fomc_ts, i))
            f_draw(c_fomc, "FOMC\n14:00 ET")
    for i = 0 to array.size(ppi_ts) - 1
        if show_ppi and f_match(array.get(ppi_ts, i))
            f_draw(c_ppi, "PPI\n8:30 ET")
    for i = 0 to array.size(nfp_ts) - 1
        if show_nfp and f_match(array.get(nfp_ts, i))
            f_draw(c_nfp, "NFP\n8:30 ET")

// --- Alerts ------------------------------------------------------------------
alertcondition(show_cpi  and in_range, "CPI Event",  "Gold: CPI 8:30 ET")
alertcondition(show_pce  and in_range, "PCE Event",  "Gold: PCE 8:30 ET")
alertcondition(show_fomc and in_range, "FOMC Event", "Gold: FOMC 14:00 ET")
alertcondition(show_ppi  and in_range, "PPI Event",  "Gold: PPI 8:30 ET")
alertcondition(show_nfp  and in_range, "NFP Event",  "Gold: NFP 8:30 ET")
