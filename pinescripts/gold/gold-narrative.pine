// This source code is subject to the terms of the Mozilla Public License 2.0
// @version=5
indicator("Gold Macro Events", overlay=true, shorttitle="GoldNarr", max_lines_count=300, max_labels_count=300)

// ---- Inputs ----------------------------------------------------------------
show_cpi  = input.bool(true,  "CPI  8:30 ET",  group="Events")
show_pce  = input.bool(true,  "PCE  8:30 ET",  group="Events")
show_fomc = input.bool(true,  "FOMC 14:00 ET", group="Events")
show_ppi  = input.bool(false, "PPI  8:30 ET",  group="Events")
show_nfp  = input.bool(false, "NFP  8:30 ET",  group="Events")
ltr     = input.int(60, "Linie Transparenz", minval=0, maxval=95, group="Stil")
bgt     = input.int(88, "Hintergrund Transparenz", minval=70, maxval=97, group="Stil")
show_bg = input.bool(true, "Hintergrundfarbe", group="Stil")
c_cpi   = input.color(#ff9800, "CPI",  group="Farben")
c_pce   = input.color(#2196f3, "PCE",  group="Farben")
c_fomc  = input.color(#ef5350, "FOMC", group="Farben")
c_ppi   = input.color(#9c27b0, "PPI",  group="Farben")
c_nfp   = input.color(#26a69a, "NFP",  group="Farben")

// ---- Draw (jede Zeile ein Statement, keine Zeilenfortsetzung) ---------------
f_draw(col, txt) =>
    line.new(bar_index, 0.01, bar_index, 99999.0, xloc=xloc.bar_index, color=color.new(col, ltr), width=1)
    label.new(bar_index, 0, txt, xloc=xloc.bar_index, yloc=yloc.abovebar, color=color.new(col, 72), textcolor=color.white, style=label.style_label_down, size=size.small)

// ---- Datum -----------------------------------------------------------------
dd = dayofmonth(time)
mm = month(time)
yy = year(time)

// CPI
cpi_a = (yy==2024 and mm==1  and dd==11) or (yy==2024 and mm==2  and dd==13) or (yy==2024 and mm==3  and dd==12)
cpi_b = (yy==2024 and mm==4  and dd==10) or (yy==2024 and mm==5  and dd==15) or (yy==2024 and mm==6  and dd==12)
cpi_c = (yy==2024 and mm==7  and dd==11) or (yy==2024 and mm==8  and dd==14) or (yy==2024 and mm==9  and dd==11)
cpi_d = (yy==2024 and mm==10 and dd==10) or (yy==2024 and mm==11 and dd==13) or (yy==2024 and mm==12 and dd==11)
cpi_e = (yy==2025 and mm==1  and dd==15) or (yy==2025 and mm==2  and dd==12) or (yy==2025 and mm==3  and dd==12)
cpi_f = (yy==2025 and mm==4  and dd==10) or (yy==2025 and mm==5  and dd==13) or (yy==2025 and mm==6  and dd==11)
cpi_g = (yy==2025 and mm==7  and dd==15) or (yy==2025 and mm==8  and dd==12) or (yy==2025 and mm==9  and dd==10)
cpi_h = (yy==2025 and mm==10 and dd==15) or (yy==2025 and mm==11 and dd==12) or (yy==2025 and mm==12 and dd==10)
cpi_i = (yy==2026 and mm==1  and dd==14) or (yy==2026 and mm==2  and dd==11) or (yy==2026 and mm==3  and dd==11)
cpi_j = (yy==2026 and mm==4  and dd==10) or (yy==2026 and mm==5  and dd==13) or (yy==2026 and mm==6  and dd==10)
cpi_k = (yy==2026 and mm==7  and dd==15) or (yy==2026 and mm==8  and dd==12) or (yy==2026 and mm==9  and dd==9)
cpi_l = (yy==2026 and mm==10 and dd==14) or (yy==2026 and mm==11 and dd==12) or (yy==2026 and mm==12 and dd==9)
is_cpi = cpi_a or cpi_b or cpi_c or cpi_d or cpi_e or cpi_f or cpi_g or cpi_h or cpi_i or cpi_j or cpi_k or cpi_l

// PCE
pce_a = (yy==2024 and mm==2  and dd==29) or (yy==2024 and mm==3  and dd==29) or (yy==2024 and mm==4  and dd==26)
pce_b = (yy==2024 and mm==5  and dd==31) or (yy==2024 and mm==6  and dd==28) or (yy==2024 and mm==7  and dd==26)
pce_c = (yy==2024 and mm==8  and dd==30) or (yy==2024 and mm==9  and dd==27) or (yy==2024 and mm==10 and dd==31)
pce_d = (yy==2024 and mm==11 and dd==27) or (yy==2024 and mm==12 and dd==20)
pce_e = (yy==2025 and mm==1  and dd==31) or (yy==2025 and mm==2  and dd==28) or (yy==2025 and mm==3  and dd==28)
pce_f = (yy==2025 and mm==4  and dd==30) or (yy==2025 and mm==5  and dd==30) or (yy==2025 and mm==6  and dd==27)
pce_g = (yy==2025 and mm==7  and dd==31) or (yy==2025 and mm==8  and dd==29) or (yy==2025 and mm==9  and dd==26)
pce_h = (yy==2025 and mm==10 and dd==31) or (yy==2025 and mm==11 and dd==26) or (yy==2025 and mm==12 and dd==19)
pce_i = (yy==2026 and mm==1  and dd==30) or (yy==2026 and mm==2  and dd==27) or (yy==2026 and mm==3  and dd==27)
pce_j = (yy==2026 and mm==4  and dd==30) or (yy==2026 and mm==5  and dd==29) or (yy==2026 and mm==6  and dd==26)
is_pce = pce_a or pce_b or pce_c or pce_d or pce_e or pce_f or pce_g or pce_h or pce_i or pce_j

// FOMC
fomc_a = (yy==2024 and mm==1  and dd==31) or (yy==2024 and mm==3  and dd==20) or (yy==2024 and mm==5  and dd==1)
fomc_b = (yy==2024 and mm==6  and dd==12) or (yy==2024 and mm==7  and dd==31) or (yy==2024 and mm==9  and dd==18)
fomc_c = (yy==2024 and mm==11 and dd==7)  or (yy==2024 and mm==12 and dd==18)
fomc_d = (yy==2025 and mm==1  and dd==29) or (yy==2025 and mm==3  and dd==19) or (yy==2025 and mm==5  and dd==7)
fomc_e = (yy==2025 and mm==6  and dd==18) or (yy==2025 and mm==7  and dd==30) or (yy==2025 and mm==9  and dd==17)
fomc_f = (yy==2025 and mm==10 and dd==29) or (yy==2025 and mm==12 and dd==10)
fomc_g = (yy==2026 and mm==1  and dd==28) or (yy==2026 and mm==3  and dd==18) or (yy==2026 and mm==5  and dd==6)
fomc_h = (yy==2026 and mm==6  and dd==17) or (yy==2026 and mm==7  and dd==29) or (yy==2026 and mm==9  and dd==16)
fomc_i = (yy==2026 and mm==10 and dd==28) or (yy==2026 and mm==12 and dd==9)
is_fomc = fomc_a or fomc_b or fomc_c or fomc_d or fomc_e or fomc_f or fomc_g or fomc_h or fomc_i

// PPI
ppi_a = (yy==2024 and mm==1  and dd==12) or (yy==2024 and mm==2  and dd==16) or (yy==2024 and mm==3  and dd==14)
ppi_b = (yy==2024 and mm==4  and dd==11) or (yy==2024 and mm==5  and dd==14) or (yy==2024 and mm==6  and dd==13)
ppi_c = (yy==2024 and mm==7  and dd==12) or (yy==2024 and mm==8  and dd==13) or (yy==2024 and mm==9  and dd==12)
ppi_d = (yy==2024 and mm==10 and dd==11) or (yy==2024 and mm==11 and dd==14) or (yy==2024 and mm==12 and dd==12)
ppi_e = (yy==2025 and mm==1  and dd==14) or (yy==2025 and mm==2  and dd==13) or (yy==2025 and mm==3  and dd==13)
ppi_f = (yy==2025 and mm==4  and dd==11) or (yy==2025 and mm==5  and dd==15) or (yy==2025 and mm==6  and dd==12)
ppi_g = (yy==2025 and mm==7  and dd==15) or (yy==2025 and mm==8  and dd==14) or (yy==2025 and mm==9  and dd==11)
ppi_h = (yy==2025 and mm==10 and dd==14) or (yy==2025 and mm==11 and dd==13) or (yy==2025 and mm==12 and dd==11)
ppi_i = (yy==2026 and mm==1  and dd==15) or (yy==2026 and mm==2  and dd==12) or (yy==2026 and mm==3  and dd==12)
ppi_j = (yy==2026 and mm==4  and dd==9)  or (yy==2026 and mm==5  and dd==14) or (yy==2026 and mm==6  and dd==11)
is_ppi = ppi_a or ppi_b or ppi_c or ppi_d or ppi_e or ppi_f or ppi_g or ppi_h or ppi_i or ppi_j

// NFP
nfp_a = (yy==2024 and mm==1  and dd==5)  or (yy==2024 and mm==2  and dd==2)  or (yy==2024 and mm==3  and dd==8)
nfp_b = (yy==2024 and mm==4  and dd==5)  or (yy==2024 and mm==5  and dd==3)  or (yy==2024 and mm==6  and dd==7)
nfp_c = (yy==2024 and mm==7  and dd==5)  or (yy==2024 and mm==8  and dd==2)  or (yy==2024 and mm==9  and dd==6)
nfp_d = (yy==2024 and mm==10 and dd==4)  or (yy==2024 and mm==11 and dd==1)  or (yy==2024 and mm==12 and dd==6)
nfp_e = (yy==2025 and mm==1  and dd==10) or (yy==2025 and mm==2  and dd==7)  or (yy==2025 and mm==3  and dd==7)
nfp_f = (yy==2025 and mm==4  and dd==4)  or (yy==2025 and mm==5  and dd==2)  or (yy==2025 and mm==6  and dd==6)
nfp_g = (yy==2025 and mm==7  and dd==3)  or (yy==2025 and mm==8  and dd==1)  or (yy==2025 and mm==9  and dd==5)
nfp_h = (yy==2025 and mm==10 and dd==3)  or (yy==2025 and mm==11 and dd==7)  or (yy==2025 and mm==12 and dd==5)
nfp_i = (yy==2026 and mm==1  and dd==9)  or (yy==2026 and mm==2  and dd==6)  or (yy==2026 and mm==3  and dd==6)
nfp_j = (yy==2026 and mm==4  and dd==3)  or (yy==2026 and mm==5  and dd==8)  or (yy==2026 and mm==6  and dd==5)
is_nfp = nfp_a or nfp_b or nfp_c or nfp_d or nfp_e or nfp_f or nfp_g or nfp_h or nfp_i or nfp_j

// ---- Hintergrund -----------------------------------------------------------
bgcolor(show_bg and show_cpi  and is_cpi  ? color.new(c_cpi,  bgt) : na)
bgcolor(show_bg and show_pce  and is_pce  ? color.new(c_pce,  bgt) : na)
bgcolor(show_bg and show_fomc and is_fomc ? color.new(c_fomc, bgt) : na)
bgcolor(show_bg and show_ppi  and is_ppi  ? color.new(c_ppi,  bgt) : na)
bgcolor(show_bg and show_nfp  and is_nfp  ? color.new(c_nfp,  bgt) : na)

// ---- Linien und Labels -----------------------------------------------------
if barstate.isconfirmed
    if show_cpi  and is_cpi
        f_draw(c_cpi,  "CPI\n8:30 ET")
    if show_pce  and is_pce
        f_draw(c_pce,  "PCE\n8:30 ET")
    if show_fomc and is_fomc
        f_draw(c_fomc, "FOMC\n14:00 ET")
    if show_ppi  and is_ppi
        f_draw(c_ppi,  "PPI\n8:30 ET")
    if show_nfp  and is_nfp
        f_draw(c_nfp,  "NFP\n8:30 ET")

// ---- Alerts ----------------------------------------------------------------
alertcondition(show_cpi  and is_cpi,  "CPI",  "Gold: CPI 8:30 ET")
alertcondition(show_pce  and is_pce,  "PCE",  "Gold: PCE 8:30 ET")
alertcondition(show_fomc and is_fomc, "FOMC", "Gold: FOMC 14:00 ET")
alertcondition(show_ppi  and is_ppi,  "PPI",  "Gold: PPI 8:30 ET")
alertcondition(show_nfp  and is_nfp,  "NFP",  "Gold: NFP 8:30 ET")
